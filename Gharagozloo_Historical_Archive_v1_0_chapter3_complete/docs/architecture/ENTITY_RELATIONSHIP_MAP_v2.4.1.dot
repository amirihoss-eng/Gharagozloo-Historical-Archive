digraph G {
graph [rankdir=LR, bgcolor="white", pad="0.25", nodesep="0.35", ranksep="1.0", splines=ortho, fontname="Arial", label="Gharagozloo Historical Archive v2.4.1 — Entity Relationship Map", labelloc=t, fontsize=20];
node [shape=plain, fontname="Arial"]; edge [fontname="Arial", fontsize=8, color="#666666", arrowsize=0.65];
